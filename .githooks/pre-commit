#!/bin/sh
set -eu

target="roles/codex/files/config.toml"

if ! git diff --cached --name-only --diff-filter=ACMR -- "$target" | grep -qx "$target"; then
  exit 0
fi

staged_file=$(mktemp)
sanitized_file=$(mktemp)

cleanup() {
  rm -f "$staged_file" "$sanitized_file"
}

trap cleanup EXIT HUP INT TERM

git show ":$target" >"$staged_file"

awk '
function flush_pending_blanks() {
  while (pending_blank_count > 0) {
    print ""
    pending_blank_count--
  }
}

function is_table(line) {
  return line ~ /^\[[^][]+\][[:space:]]*$/
}

function marketplace_is_local(line) {
  return line ~ /^[[:space:]]*source_type[[:space:]]*=[[:space:]]*"local"[[:space:]]*$/ ||
    line ~ /^[[:space:]]*source[[:space:]]*=[[:space:]]*"\/Users\//
}

function start_marketplace(line) {
  in_marketplace = 1
  marketplace_local = 0
  marketplace_line_count = 1
  marketplace_lines[marketplace_line_count] = line
}

function buffer_marketplace(line) {
  marketplace_lines[++marketplace_line_count] = line
  if (marketplace_is_local(line)) {
    marketplace_local = 1
  }
}

function flush_marketplace() {
  if (!in_marketplace) {
    return
  }

  if (!marketplace_local) {
    flush_pending_blanks()
    for (marketplace_line_index = 1; marketplace_line_index <= marketplace_line_count; marketplace_line_index++) {
      print marketplace_lines[marketplace_line_index]
    }
  }

  delete marketplace_lines
  in_marketplace = 0
  marketplace_local = 0
  marketplace_line_count = 0
}

in_marketplace && is_table($0) {
  flush_marketplace()
}

in_marketplace {
  buffer_marketplace($0)
  next
}

/^\[projects\.[^][]+\][[:space:]]*$/ {
  skip_projects = 1
  next
}

skip_projects && is_table($0) {
  skip_projects = 0
}

skip_projects {
  next
}

/^\[marketplaces\.[^][]+\][[:space:]]*$/ {
  start_marketplace($0)
  next
}

/^[[:space:]]*trust_level[[:space:]]*=/ {
  next
}

/^[[:space:]]*$/ {
  pending_blank_count++
  next
}

{
  flush_pending_blanks()
  print
}

END {
  flush_marketplace()
}
' "$staged_file" >"$sanitized_file"

mode=$(git ls-files -s -- "$target" | awk 'NR == 1 { print $1 }')

if [ -z "$mode" ]; then
  echo "pre-commit: unable to determine index mode for $target" >&2
  exit 1
fi

blob=$(git hash-object -w --path "$target" "$sanitized_file")
git update-index --cacheinfo "$mode,$blob,$target"
