#!/bin/sh
set -eu

target="roles/codex/files/config.toml"

if ! git diff --cached --name-only --diff-filter=ACMR -- "$target" | grep -qx "$target"; then
  exit 0
fi

staged_file=$(mktemp)
sanitized_file=$(mktemp)

cleanup() {
  rm -f "$staged_file" "$sanitized_file"
}

trap cleanup EXIT HUP INT TERM

git show ":$target" >"$staged_file"

awk '
function flush_pending_blanks() {
  while (pending_blank_count > 0) {
    print ""
    pending_blank_count--
  }
}

/^\[projects\.[^][]+\][[:space:]]*$/ {
  skip_projects = 1
  next
}

skip_projects && /^\[[^][]+\][[:space:]]*$/ {
  skip_projects = 0
}

skip_projects {
  next
}

/^[[:space:]]*trust_level[[:space:]]*=/ {
  next
}

/^[[:space:]]*$/ {
  pending_blank_count++
  next
}

{
  flush_pending_blanks()
  print
}
' "$staged_file" >"$sanitized_file"

mode=$(git ls-files -s -- "$target" | awk 'NR == 1 { print $1 }')

if [ -z "$mode" ]; then
  echo "pre-commit: unable to determine index mode for $target" >&2
  exit 1
fi

blob=$(git hash-object -w --path "$target" "$sanitized_file")
git update-index --cacheinfo "$mode,$blob,$target"
