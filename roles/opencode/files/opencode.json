{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "plugin": ["oh-my-opencode"],
  "model": "openai/gpt-5.4",
  "agent": {
    "build": {
      "variant": "xhigh"
    },
    "plan": {
      "variant": "xhigh"
    }
  },
  "provider": {
    "openai": {
      "models": {
        "gpt-5.4": {
          "options": {
            "reasoningEffort": "xhigh"
          }
        }
      }
    }
  },
  "permission": {
    "bash": {
      "*": "allow",
      "sudo *": "ask",
      "su *": "ask",
      "passwd *": "ask",
      "shutdown *": "deny",
      "reboot *": "deny",
      "halt *": "deny",
      "poweroff *": "deny",
      "systemctl reboot": "deny",
      "systemctl poweroff": "deny",
      "systemctl halt": "deny",
      "rm -rf /": "deny",
      "rm -rf /*": "deny",
      "dd if=/dev/zero of=/dev/*": "deny",
      "mkfs *": "deny",
      "fdisk *": "deny",
      "parted *": "deny",
      "git commit *": "ask",
      "git push *": "ask",
      "git merge *": "ask",
      "git rebase *": "ask",
      "git reset *": "ask",
      "git revert *": "ask",
      "git cherry-pick *": "ask",
      "git tag *": "ask",
      "chmod 777 *": "deny",
      "chown root *": "deny"
    },
    "edit": "allow",
    "webfetch": "allow"
  }
}
