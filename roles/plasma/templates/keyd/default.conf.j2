# Managed by the dotfiles Plasma role.
# Wayland-safe summon leader:
# - tap Caps Lock/F13 once, then a logical app letter to emit F13 + that letter
# - tap Caps Lock/F13 twice, then a logical macro letter to run the macro action
#
# keyd matches physical key names before the compositor applies the keyboard
# layout. Keep the app layers broad so QWERTY and Dvorak logical letters both
# reach the same KWin F13,<letter> shortcuts.
{% set app_passthrough_keys = [
  'a', 'b', 'c', 'd', 'e', 'f', 'g', 'h', 'i', 'j', 'k', 'l', 'm',
  'n', 'o', 'p', 'q', 'r', 's', 't', 'u', 'v', 'w', 'x', 'y', 'z',
  'semicolon', 'comma', 'dot', 'slash'
] %}
{% set keyboard_variant = (keyboard | default({})).variant | default('') %}
[ids]
*

[global]
oneshot_timeout = 2000

[main]
capslock = overload(plasma_summon, oneshot(plasma_leader))
f13 = overload(plasma_summon, oneshot(plasma_leader))

[plasma_summon]
{% for key in app_passthrough_keys %}
{{ key }} = macro(f13 {{ key }})
{% endfor %}
esc = clear()
f13 = clear()
capslock = clear()

[plasma_leader]
{% for key in app_passthrough_keys %}
{{ key }} = macro(f13 {{ key }})
{% endfor %}
capslock = oneshot(plasma_macro_action)
f13 = oneshot(plasma_macro_action)
esc = clear()

[plasma_macro_action]
a = command(/usr/local/bin/plasma-summon-keyd run cycle_same_app)
{% if keyboard_variant == 'dvorak' %}
semicolon = command(/usr/local/bin/plasma-summon-keyd run screenshot_area)
d = command(/usr/local/bin/plasma-summon-keyd run emoji_picker)
{% else %}
s = command(/usr/local/bin/plasma-summon-keyd run screenshot_area)
e = command(/usr/local/bin/plasma-summon-keyd run emoji_picker)
{% endif %}
esc = clear()
f13 = clear()
capslock = clear()
